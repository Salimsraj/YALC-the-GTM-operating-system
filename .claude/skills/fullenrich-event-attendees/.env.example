# FullEnrich (always required)
FULLENRICH_API_KEY=

# Apify mode only — bring your own Apify account + LinkedIn cookies.
# Skip these if you're using --input attendees.csv (CSV mode).

APIFY_TOKEN=

# LinkedIn session cookies (only needed by Apify actors that scrape attendees).
# How to extract:
#   1. Log into LinkedIn in Chrome
#   2. Open DevTools → Application → Cookies → linkedin.com
#   3. Copy the values of li_at and JSESSIONID
#   4. Paste below
# These rotate every few weeks; refresh as needed.
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# Full User-Agent string from the SAME browser. Get from chrome://version
# or https://www.whatismybrowser.com/detect/what-is-my-user-agent
LINKEDIN_USER_AGENT=

# Optional. Public URL where FullEnrich posts the enrichment callback. If unset,
# the script provisions a one-shot webhook.site URL automatically.
# FULLENRICH_WEBHOOK_URL=
