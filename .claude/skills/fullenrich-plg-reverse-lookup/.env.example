# FullEnrich (required)
FULLENRICH_API_KEY=

# --- Webhook mode (Vercel deploy) safeguards ---

# Hard daily credit ceiling. Webhook returns HTTP 429 once exceeded.
MAX_CREDITS_PER_DAY=200

# Set to 1 for the first 24h after deploy. Logs intent only; no FullEnrich calls.
WEBHOOK_DRY_RUN=1

# --- Optional output destinations ---

# Append every enriched signup to this JSONL file. Default: /tmp/plg-enriched.jsonl
# Set to "" to disable.
# PLG_LOG_PATH=/tmp/plg-enriched.jsonl

# Forward each enriched record as a POST request to any URL you choose
# (your CRM webhook, your data warehouse ingest endpoint, an automation tool, etc).
# FORWARD_WEBHOOK_URL=

# --- Optional ---

# Public URL where FullEnrich posts the enrichment callback. Auto-provisioned
# via webhook.site when running the CLI batch script without this set.
# FULLENRICH_WEBHOOK_URL=
