{
  "buildCommand": "pnpm build:web",
  "outputDirectory": "web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|_next/static|_next/image|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
